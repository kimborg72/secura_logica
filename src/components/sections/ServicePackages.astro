---
import Button from '@components/ui/Button.astro';
import type { Locale } from '@i18n/types';
import { getContactPath } from '@i18n/routes';

interface PackageStep {
  number: number;
  title: string;
  description: string;
}

interface ServicePackage {
  name: string;
  duration: string;
  durationLabel: string;
  description: string;
  steps: PackageStep[];
  ctaLabel: string;
  accent?: 'teal' | 'lime';
}

interface Props {
  packages: ServicePackage[];
  locale?: Locale;
  overline?: string;
  heading?: string;
}

const { packages, locale = 'sv', overline, heading } = Astro.props;
const contactHref = getContactPath(locale);
---

<section class="section">
  <div class="container">
    {(overline || heading) && (
      <div class="max-w-2xl mb-12" data-reveal>
        {overline && <p class="overline mb-3">{overline}</p>}
        {heading && <h2>{heading}</h2>}
      </div>
    )}

    <div class="grid lg:grid-cols-2 gap-8">
      {packages.map((pkg, i) => (
        <article
          class:list={[
            'package-card bg-surface rounded-xl border border-border p-8 lg:p-10 relative overflow-hidden',
            pkg.accent === 'lime' ? 'accent-lime' : 'accent-teal',
          ]}
          data-reveal
          data-delay={String(i + 1)}
        >
          <div class="flex items-center gap-2 mb-4">
            <span class="overline text-navy/60">{pkg.durationLabel}</span>
            <span class="text-xs font-semibold text-navy bg-white border border-border rounded px-2 py-0.5">
              {pkg.duration}
            </span>
          </div>
          <h3 class="text-2xl font-bold text-navy mb-4">{pkg.name}</h3>
          <p class="text-slate leading-relaxed mb-8">{pkg.description}</p>

          <ol class="space-y-5 mb-10">
            {pkg.steps.map((step) => (
              <li class="flex gap-4">
                <div class="shrink-0 w-9 h-9 flex items-center justify-center rounded-full bg-navy text-white font-bold text-sm">
                  {step.number}
                </div>
                <div class="pt-1">
                  <h4 class="font-semibold text-navy mb-1 text-base">{step.title}</h4>
                  <p class="text-sm text-gray leading-relaxed">{step.description}</p>
                </div>
              </li>
            ))}
          </ol>

          <Button href={contactHref} variant="primary" size="md">
            {pkg.ctaLabel}
          </Button>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .package-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .package-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
  }
  .package-card.accent-teal::before {
    background: var(--color-teal);
  }
  .package-card.accent-lime::before {
    background: var(--color-accent);
  }
  .package-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(18, 18, 18, 0.15);
  }
</style>
