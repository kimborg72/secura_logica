---
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import type { Locale } from '@i18n/types';

interface Props {
  title: string;
  description?: string;
  breadcrumbs?: Array<{ label: string; href?: string }>;
  bgImage?: string;
  bgImageAlt?: string;
  locale?: Locale;
}

const { title, description, breadcrumbs, bgImage, bgImageAlt = '', locale = 'sv' } = Astro.props;
const hasBg = !!bgImage;
---

<section
  class:list={[
    'relative -mt-20 pt-32 pb-20 overflow-hidden',
    hasBg ? '' : 'bg-surface pb-16',
  ]}
>
  {hasBg && (
    <>
      <img
        src={bgImage}
        alt={bgImageAlt}
        width="1920"
        height="1072"
        class="absolute inset-0 w-full h-full object-cover"
        fetchpriority="high"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-navy-dark/75"></div>
    </>
  )}
  <div
    class:list={[
      'container relative z-10',
      hasBg && '[&_nav_a]:text-white/70 [&_nav_a:hover]:text-white [&_nav_li]:text-white/70 [&_nav_svg]:text-white/40',
    ]}
  >
    {breadcrumbs && <Breadcrumb items={breadcrumbs} locale={locale} />}
    <div class="max-w-3xl mt-6">
      <h1 class:list={[hasBg && 'text-white']}>{title}</h1>
      {description && (
        <p class:list={['lead mt-4', hasBg && 'text-white/70']}>{description}</p>
      )}
    </div>
  </div>
</section>
