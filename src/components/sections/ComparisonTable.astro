---
import type { Locale } from '@i18n/types';

interface Row {
  dimension: string;
  generic: string;
  fasttrack: string;
}

interface Props {
  rows: Row[];
  locale?: Locale;
  dimensionLabel: string;
  genericLabel: string;
  fasttrackLabel: string;
  overline?: string;
  heading?: string;
}

const { rows, dimensionLabel, genericLabel, fasttrackLabel, overline, heading } = Astro.props;
---

<section class="section bg-surface">
  <div class="container">
    {(overline || heading) && (
      <div class="max-w-2xl mb-12" data-reveal>
        {overline && <p class="overline mb-3">{overline}</p>}
        {heading && <h2>{heading}</h2>}
      </div>
    )}

    <!-- Desktop: real table -->
    <div class="hidden md:block" data-reveal>
      <div class="overflow-hidden rounded-xl border border-border bg-white">
        <table class="w-full">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left text-xs font-semibold text-gray uppercase tracking-wider py-4 px-6">
                {dimensionLabel}
              </th>
              <th class="text-left text-xs font-semibold text-gray uppercase tracking-wider py-4 px-6">
                {genericLabel}
              </th>
              <th class="text-left text-xs font-bold text-navy uppercase tracking-wider py-4 px-6 bg-accent">
                {fasttrackLabel}
              </th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row, i) => (
              <tr class:list={['border-b border-border last:border-0', i % 2 === 1 ? 'bg-surface/50' : '']}>
                <td class="py-5 px-6 text-sm font-semibold text-navy align-top">{row.dimension}</td>
                <td class="py-5 px-6 text-sm text-gray align-top">{row.generic}</td>
                <td class="py-5 px-6 text-sm font-semibold text-navy align-top bg-accent/10">
                  {row.fasttrack}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Mobile: stacked comparison cards -->
    <div class="md:hidden space-y-4">
      {rows.map((row, i) => (
        <div class="bg-white rounded-xl border border-border overflow-hidden" data-reveal data-delay={String((i % 3) + 1)}>
          <div class="px-5 py-3 bg-navy text-white">
            <span class="text-xs font-semibold uppercase tracking-wider">{row.dimension}</span>
          </div>
          <div class="divide-y divide-border">
            <div class="px-5 py-4">
              <p class="text-xs font-semibold text-gray uppercase tracking-wider mb-1">{genericLabel}</p>
              <p class="text-sm text-gray">{row.generic}</p>
            </div>
            <div class="px-5 py-4 bg-accent/10">
              <p class="text-xs font-bold text-navy uppercase tracking-wider mb-1">{fasttrackLabel}</p>
              <p class="text-sm font-semibold text-navy">{row.fasttrack}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
