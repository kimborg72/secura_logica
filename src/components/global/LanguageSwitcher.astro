---
import type { Locale } from '@i18n/types';
import { t } from '@i18n/index';
import { getAlternateUrl } from '@i18n/routes';

interface Props {
  locale: Locale;
  svOnly?: boolean;
  class?: string;
}

const { locale, svOnly = false, class: className } = Astro.props;

const svHref = locale === 'sv' ? Astro.url.pathname : getAlternateUrl(Astro.url.pathname, 'sv');
// On Swedish-only pages, link EN to the English homepage instead of the same SV path
const enHref = svOnly
  ? '/en'
  : (locale === 'en' ? Astro.url.pathname : getAlternateUrl(Astro.url.pathname, 'en'));
---

<div class:list={["flex items-center gap-1 text-sm font-medium", className]} role="navigation" aria-label={t(locale, 'lang.aria')}>
  <a
    href={svHref}
    class:list={[
      "px-1.5 py-0.5 rounded transition-colors",
      locale === 'sv' ? 'font-bold' : 'opacity-75 hover:opacity-100'
    ]}
    aria-current={locale === 'sv' ? 'true' : undefined}
    hreflang="sv"
    data-header-text
  >
    SV
  </a>
  <span class="opacity-40" data-header-text>/</span>
  <a
    href={enHref}
    class:list={[
      "px-1.5 py-0.5 rounded transition-colors",
      locale === 'en' ? 'font-bold' : 'opacity-75 hover:opacity-100'
    ]}
    aria-current={locale === 'en' ? 'true' : undefined}
    hreflang="en"
    data-header-text
  >
    EN
  </a>
</div>
