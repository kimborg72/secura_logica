---
interface Props {
  name: string;
  lat: number;
  lng: number;
}

const { name, lat, lng } = Astro.props;
const apiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_KEY;
const mapId = import.meta.env.PUBLIC_GOOGLE_MAP_ID;

const useJsApi = !!(apiKey && mapId);

const embedSrc = apiKey
  ? `https://www.google.com/maps/embed/v1/view?key=${apiKey}&center=${lat},${lng}&zoom=10&language=sv`
  : `https://www.google.com/maps?q=${lat},${lng}&z=10&output=embed&hl=sv`;
---

<div>
  <p class="text-center mb-3">
    <span class="text-sm font-medium text-navy">{name}</span>
    <span class="block text-xs text-gray mt-0.5">{lat.toFixed(2)}°N, {lng.toFixed(2)}°E</span>
  </p>
  {useJsApi ? (
    <div class="aspect-[4/3] w-full overflow-hidden rounded-lg">
      <div
        class="sweden-map w-full h-full"
        data-lat={lat}
        data-lng={lng}
        data-map-id={mapId}
      ></div>
    </div>
  ) : (
    <div class="aspect-[4/3] w-full overflow-hidden rounded-lg">
      <iframe
        src={embedSrc}
        width="100%"
        height="100%"
        style="border:0;"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={`Karta som visar ${name}`}
        allowfullscreen
      ></iframe>
    </div>
  )}
</div>

<script is:inline define:vars={{ apiKey, useJsApi }}>
  function __initSwedenMap() {
    if (!useJsApi) return;
    var mapEl = document.querySelector('.sweden-map');
    if (!mapEl || mapEl.dataset.initialized) return;
    mapEl.dataset.initialized = 'true';

    var lat = parseFloat(mapEl.dataset.lat);
    var lng = parseFloat(mapEl.dataset.lng);
    var mapId = mapEl.dataset.mapId;

    new google.maps.Map(mapEl, {
      center: { lat: lat, lng: lng },
      zoom: 10,
      mapId: mapId,
      disableDefaultUI: true,
      zoomControl: false,
      gestureHandling: 'none',
    });
  }

  function __loadSwedenMap() {
    if (!useJsApi) return;
    if (window.google && window.google.maps) {
      __initSwedenMap();
      return;
    }
    if (!document.querySelector('script[src*="maps.googleapis.com"]')) {
      var s = document.createElement('script');
      s.src = 'https://maps.googleapis.com/maps/api/js?key=' + apiKey + '&callback=__initSwedenMap&v=weekly';
      s.async = true;
      s.defer = true;
      document.head.appendChild(s);
    }
  }

  __loadSwedenMap();
  document.addEventListener('astro:page-load', __loadSwedenMap);
</script>
