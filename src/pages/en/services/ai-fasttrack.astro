---
import PageLayout from '@layouts/PageLayout.astro';
import HeroSimple from '@components/sections/HeroSimple.astro';
import CTABanner from '@components/sections/CTABanner.astro';
import ServicePackages from '@components/sections/ServicePackages.astro';
import ComparisonTable from '@components/sections/ComparisonTable.astro';
import ServiceCard from '@components/ui/ServiceCard.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import { site, organizationSchema } from '@data/site';
import { getServicesByLocale } from '@i18n/content';
import { getServicePath, getServicesPath } from '@i18n/routes';

const locale = 'en' as const;
const slug = 'ai-fasttrack';

const allServices = await getServicesByLocale(locale);
const relatedSlugs = ['ciso-as-a-service', 'risk-management', 'nis2'];
const relatedServices = allServices.filter((s) => relatedSlugs.includes(s.data.slug));

const metaTitle = 'AI FastTrack — Governance & Security | Verit';
const metaDescription =
  'The shortest path from AI ambition to a governable business capability. AI governance and cybersecurity integrated at every step.';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'AI FastTrack — Governance & Security',
  description: metaDescription,
  provider: {
    '@type': 'Organization',
    name: organizationSchema.name,
    url: organizationSchema.url,
  },
  areaServed: { '@type': 'Country', name: 'Sweden' },
  url: `${site.url}${getServicePath(locale, slug)}`,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does AI FastTrack differ from a typical AI consultancy?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A typical AI consultancy focuses on tools and technical pilots. AI FastTrack starts from decisions and business impact — and treats security as an integrated dimension, not a phase 2 exercise. We also map requirements from NIS2, the EU AI Act and GDPR directly into the delivery.',
      },
    },
    {
      '@type': 'Question',
      name: "We're early with AI — is this for us?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. The Readiness Assessment (2–3 days) is designed for exactly that situation. You get a rapid evaluation of AI maturity and security readiness, plus 3–5 concrete recommendations that leadership can act on immediately.',
      },
    },
    {
      '@type': 'Question',
      name: 'What happens after delivery?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'You have a concrete roadmap with integrated security measures and a clear maturity ladder. We can support implementation over time through CISO-as-a-Service or Securapilot — or you can take it forward on your own.',
      },
    },
  ],
};

const challenges = [
  {
    title: 'Tools without strategy',
    description:
      'AI tools are purchased without a link to business decisions or strategic objectives. Pilots run in parallel without a shared direction.',
  },
  {
    title: 'Security as an afterthought',
    description:
      'Control, compliance and risk management are pushed to "phase 2" — if at all. Policies are missing before the models go live.',
  },
  {
    title: 'No shared language',
    description:
      'IT, business, HR and leadership speak different languages about AI. Decisions stall or get postponed indefinitely.',
  },
];

const packages = [
  {
    name: 'Readiness Assessment',
    duration: '2–3 days',
    durationLabel: 'Timeframe',
    description:
      'Rapid assessment of AI maturity and security readiness. Current state, gaps and 3–5 concrete recommendations leadership can act on immediately.',
    accent: 'teal' as const,
    ctaLabel: 'Book Readiness Assessment',
    steps: [
      {
        number: 1,
        title: 'Rapid interviews',
        description:
          'AI maturity, security posture, data quality and governance in a single interview round with key stakeholders.',
      },
      {
        number: 2,
        title: 'Integrated gap analysis',
        description:
          'Assessment against a maturity scale covering both AI capability and security requirements — on a shared map.',
      },
      {
        number: 3,
        title: 'Leadership report',
        description:
          'Current state, risks and 3–5 recommendations that address both value and security.',
      },
    ],
  },
  {
    name: 'Governance & Security',
    duration: '5–7 weeks',
    durationLabel: 'Timeframe',
    description:
      'Full engagement — decision mapping, governance model, data pipelines, control framework and a roadmap with integrated security measures.',
    accent: 'lime' as const,
    ctaLabel: 'Get in touch',
    steps: [
      {
        number: 1,
        title: 'Current state, ambition & threat picture',
        description:
          'Interviews with leadership. AI expectations, decision processes, security posture, shadow AI and regulatory requirements.',
      },
      {
        number: 2,
        title: 'Decision mapping & risk analysis',
        description:
          'Decisions with the greatest AI leverage. Data flows, threats, protection level and vulnerability per decision point.',
      },
      {
        number: 3,
        title: 'Prioritisation workshop',
        description:
          'Rate AI initiatives by business value, feasibility and security risk. Unclear controls = stop criterion.',
      },
      {
        number: 4,
        title: 'Governance, roles & control framework',
        description:
          'Decision rights, responsibilities, escalation paths, policies and incident handling.',
      },
      {
        number: 5,
        title: 'Data pipelines & protection architecture',
        description:
          'Data from source to model to decision. Classification, access, traceability and supplier review.',
      },
      {
        number: 6,
        title: 'Follow-up framework',
        description:
          'KPIs for business impact complemented with security indicators — incidents, deviations, policy violations.',
      },
      {
        number: 7,
        title: 'Roadmap & maturity ladder',
        description:
          'A concrete plan with integrated security measures in every phase. What does security require before the next AI maturity step?',
      },
    ],
  },
];

const comparisonRows = [
  {
    dimension: 'Security',
    generic: 'Handled in phase 2',
    fasttrack: 'Integrated in every step',
  },
  {
    dimension: 'Focus',
    generic: 'Tools and technology',
    fasttrack: 'Decisions and business impact',
  },
  {
    dimension: 'Regulation',
    generic: 'Mentioned when needed',
    fasttrack: 'NIS2 + EU AI Act + GDPR mapped',
  },
  {
    dimension: 'Delivery',
    generic: 'Report and recommendations',
    fasttrack: 'Governance, control framework and roadmap',
  },
  {
    dimension: 'Follow-up',
    generic: 'Rarely included',
    fasttrack: 'KPIs + security indicators',
  },
];

const expectations = [
  'Prioritise the right AI initiatives — identify where AI creates real business value first',
  'Turn AI into a question of decision governance — understand which decisions should be supported, augmented or owned by humans',
  'Create a shared language across functions — bring leadership, operations, IT, HR and risk around a common model',
  'Redesign workflows — map how work moves before, around and after a decision',
  'Redesign data pipelines — surface which data must exist and how it must flow',
  'Build in accountability, control and guardrails — roles, decision rights, control points, policies and escalation paths',
  'Track real impact — separate perceived value from actual business outcomes',
  'Assess the next maturity step — decide when AI should support, augment or be delegated',
];
---

<PageLayout
  title={metaTitle}
  description={metaDescription}
  ogImage="/og/en/services/ai-fasttrack.png"
  locale={locale}
>
  <JsonLd schema={serviceSchema} />
  <JsonLd schema={faqSchema} />

  <HeroSimple
    title="AI FastTrack — Governance & Security"
    description="The shortest path from AI ambition to a governable business capability."
    breadcrumbs={[
      { label: 'Services', href: getServicesPath(locale) },
      { label: 'AI FastTrack' },
    ]}
    locale={locale}
  />

  <!-- Intro & core principle -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="overline mb-4">About the service</p>
        <p class="lead text-slate mb-6">
          Everyone is talking about accelerating AI. We make sure you actually can — without losing control.
          AI FastTrack helps leadership teams move from AI as activity to AI as a governable business
          capability, with security integrated at every step.
        </p>
        <p class="text-gray leading-relaxed mb-4">
          We combine decision mapping, risk analysis, governance model and control framework in one
          coherent delivery. The result is a clear picture of where AI creates the most value —
          and exactly which security measures are required before you take the next step.
        </p>
      </div>

      <div class="mt-10 max-w-3xl bg-surface border-l-4 border-teal rounded-xl p-6 lg:p-8" data-reveal>
        <p class="overline mb-2 text-teal-dark">Core principle</p>
        <p class="text-xl lg:text-2xl font-semibold text-navy leading-snug">
          No AI maturity without matching security maturity.
        </p>
        <p class="mt-3 text-sm text-gray italic">Method first. Tools second. Security always.</p>
      </div>
    </div>
  </section>

  <!-- The challenge -->
  <section class="section-sm bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="overline mb-3">The challenge</p>
        <h2>Organisations get stuck</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {challenges.map((c, i) => (
          <div
            class="bg-white rounded-xl border border-border p-6 lg:p-8 relative"
            data-reveal
            data-delay={String(i + 1)}
          >
            <div class="text-4xl font-bold text-navy/10 mb-3 leading-none">
              {String(i + 1).padStart(2, '0')}
            </div>
            <h3 class="text-lg font-semibold text-navy mb-3">{c.title}</h3>
            <p class="text-sm text-gray leading-relaxed">{c.description}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center" data-reveal>
        <p class="inline-block text-sm font-semibold text-accent-dark bg-accent/25 px-4 py-2 rounded-full italic">
          Result: AI becomes a cost, not a capability.
        </p>
      </div>
    </div>
  </section>

  <!-- Two packages -->
  <ServicePackages
    packages={packages}
    locale={locale}
    overline="AI FastTrack"
    heading="Choose your starting point"
  />

  <!-- Comparison table -->
  <ComparisonTable
    rows={comparisonRows}
    dimensionLabel="Dimension"
    genericLabel="Typical AI consultancy"
    fasttrackLabel="AI FastTrack"
    overline="Comparison"
    heading="Why AI FastTrack?"
    locale={locale}
  />

  <!-- What leadership gets -->
  <section class="section">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="overline mb-3">What you get</p>
        <h2>What leadership can expect</h2>
      </div>

      <ul class="grid md:grid-cols-2 gap-6 lg:gap-8">
        {expectations.map((item, i) => (
          <li
            class="flex items-start gap-4 bg-surface rounded-xl border border-border p-5 lg:p-6"
            data-reveal
            data-delay={String((i % 4) + 1)}
          >
            <div class="shrink-0 w-10 h-10 rounded-full bg-teal/15 flex items-center justify-center">
              <svg
                class="w-5 h-5 text-teal-dark"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="text-slate leading-relaxed text-sm lg:text-base pt-1">{item}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Related services -->
  {relatedServices.length > 0 && (
    <section class="section-sm bg-surface">
      <div class="container">
        <h2 class="mb-10" data-reveal>Related services</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {relatedServices.map((s, i) => (
            <div data-reveal data-delay={String(i + 1)}>
              <ServiceCard
                title={s.data.title}
                description={s.data.excerpt}
                href={getServicePath(locale, s.data.slug)}
                locale={locale}
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTABanner
    title="Ready to start?"
    description="Book a Readiness Assessment — 2–3 days that give leadership a concrete decision foundation."
    buttonText="Book Readiness Assessment"
    locale={locale}
  />
</PageLayout>
