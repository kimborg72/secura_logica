---
import PageLayout from '@layouts/PageLayout.astro';
import HeroSimple from '@components/sections/HeroSimple.astro';
import CTABanner from '@components/sections/CTABanner.astro';
import ServicePackages from '@components/sections/ServicePackages.astro';
import ComparisonTable from '@components/sections/ComparisonTable.astro';
import ServiceCard from '@components/ui/ServiceCard.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import { site, organizationSchema } from '@data/site';
import { getServicesByLocale } from '@i18n/content';
import { getServicePath, getServicesPath, getInsightPath } from '@i18n/routes';

const locale = 'en' as const;
const slug = 'ai-fasttrack';

const allServices = await getServicesByLocale(locale);
const relatedSlugs = ['ciso-as-a-service', 'risk-management', 'nis2'];
const relatedServices = allServices.filter((s) => relatedSlugs.includes(s.data.slug));

const metaTitle = 'AI Security & Governance: AI FastTrack | Verit';
const metaDescription =
  'AI security and governance integrated at every step. AI FastTrack removes the stop-and-go so each AI initiative builds on the last — NIS2 and EU AI Act mapped in.';

const pageUrl = `${site.url}${getServicePath(locale, slug)}`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'AI FastTrack — AI Security & Governance',
  description: metaDescription,
  serviceType: 'AI Governance Consulting',
  provider: {
    '@type': 'Organization',
    name: organizationSchema.name,
    url: organizationSchema.url,
  },
  areaServed: { '@type': 'Country', name: 'Sweden' },
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'Executive leadership, CISOs, IT directors, boards',
  },
  url: pageUrl,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does AI FastTrack differ from a typical AI consultancy?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A typical AI consultancy focuses on tools and technical pilots. AI FastTrack starts from decisions and business impact, and treats AI security as an integrated dimension rather than a phase 2 exercise. We also map requirements from NIS2, the EU AI Act and GDPR directly into the delivery.',
      },
    },
    {
      '@type': 'Question',
      name: "We're early with AI. Is this for us?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. The Readiness Assessment (2–3 days) is built for exactly that situation. You get a rapid evaluation of AI maturity and security readiness, plus three to five recommendations leadership can act on immediately.',
      },
    },
    {
      '@type': 'Question',
      name: 'What happens after delivery?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'You have a roadmap with integrated security measures and a clear maturity ladder. We can support implementation over time through CISO-as-a-Service, or you can take it forward on your own.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does AI FastTrack cover EU AI Act and NIS2 requirements?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. We map requirements from the EU AI Act, NIS2 directive, GDPR and ISO/IEC 42001 to your delivery. You get documentation showing where you stand, what remains, and which controls to prioritise first.',
      },
    },
  ],
};

const challenges = [
  {
    title: 'Tools without strategy',
    description:
      'AI tools are bought without a link to business decisions. Pilots run in parallel with no shared direction, and no one knows which one to scale.',
  },
  {
    title: 'Security as an afterthought',
    description:
      'Control, compliance and risk management get pushed to "phase 2", if they get there at all. Models go into production before policies exist.',
  },
  {
    title: 'No shared language',
    description:
      'IT, business, HR and leadership speak different languages about AI. Decisions stall or get postponed indefinitely.',
  },
];

const packages = [
  {
    name: 'Readiness Assessment',
    duration: '2–3 days',
    durationLabel: 'Timeframe',
    description:
      'Rapid assessment of AI maturity and security readiness. You get current state, gaps and three to five recommendations leadership can act on immediately.',
    accent: 'teal' as const,
    ctaLabel: 'Book Readiness Assessment',
    steps: [
      {
        number: 1,
        title: 'Rapid interviews',
        description:
          'AI maturity, security posture, data quality and governance in a single interview round with key stakeholders, instead of five separate workshops.',
      },
      {
        number: 2,
        title: 'Integrated gap analysis',
        description:
          'Assessment against a maturity scale where AI capability and security requirements sit on the same map.',
      },
      {
        number: 3,
        title: 'Leadership report',
        description:
          'Current state, risks and three to five recommendations that address both value and security.',
      },
    ],
  },
  {
    name: 'Governance & Security',
    duration: '5–7 weeks',
    durationLabel: 'Timeframe',
    description:
      'Full engagement. Decision mapping, governance model, data pipelines, control framework and a roadmap with security measures integrated in every phase. NIS2, the EU AI Act, GDPR and ISO/IEC 42001 are mapped in from the start.',
    accent: 'lime' as const,
    ctaLabel: 'Get in touch',
    steps: [
      {
        number: 1,
        title: 'Current state, ambition and threat picture',
        description:
          'Interviews with leadership about AI expectations, decision processes, security posture, shadow AI and regulatory requirements.',
      },
      {
        number: 2,
        title: 'Decision mapping and risk analysis',
        description:
          'Decisions with the greatest AI leverage. Data flows, threats, protection level and vulnerability per decision point.',
      },
      {
        number: 3,
        title: 'Prioritisation workshop',
        description:
          'Rate AI initiatives by business value, feasibility and security risk. Unclear controls become a stop criterion.',
      },
      {
        number: 4,
        title: 'Governance, roles and control framework',
        description:
          'Decision rights, responsibilities, escalation paths, policies and incident handling.',
      },
      {
        number: 5,
        title: 'Data pipelines and protection architecture',
        description:
          'Data from source to model to decision. Classification, access, traceability and supplier review.',
      },
      {
        number: 6,
        title: 'Follow-up framework',
        description:
          'KPIs for business impact complemented with security indicators: incidents, deviations and policy violations.',
      },
      {
        number: 7,
        title: 'Roadmap and maturity ladder',
        description:
          'A plan with security measures in every phase. What does security require before the next AI maturity step?',
      },
    ],
  },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'AI FastTrack packages',
  itemListElement: packages.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Service',
      name: `AI FastTrack — ${p.name}`,
      description: p.description,
      provider: { '@type': 'Organization', name: organizationSchema.name },
    },
  })),
};

const comparisonRows = [
  {
    dimension: 'AI security',
    generic: 'Handled in phase 2',
    fasttrack: 'Integrated in every step',
  },
  {
    dimension: 'Focus',
    generic: 'Tools and technology',
    fasttrack: 'Decisions and business impact',
  },
  {
    dimension: 'Regulation',
    generic: 'Mentioned when needed',
    fasttrack: 'NIS2, EU AI Act, GDPR and ISO 42001 mapped',
  },
  {
    dimension: 'Delivery',
    generic: 'Report and recommendations',
    fasttrack: 'Governance, control framework and roadmap',
  },
  {
    dimension: 'Follow-up',
    generic: 'Rarely included',
    fasttrack: 'KPIs plus security indicators',
  },
  {
    dimension: 'Pace over time',
    generic: 'Fast pilot, then it stalls',
    fasttrack: 'Each initiative faster than the last',
  },
];

const expectations = [
  'Clear prioritisation. You see where AI actually creates business value first, instead of spreading effort across every possible pilot.',
  'AI as decision governance. Which decisions should be supported, which augmented, and which should never be automated.',
  'A shared language. Leadership, operations, IT, HR and risk align on one model for AI, decisions and security.',
  'Redesigned workflows. We map how work moves before, around and after a decision.',
  'Redesigned data pipelines. What data must exist, and how must it flow for the model to be reliable?',
  'Built-in accountability. Roles, decision rights, control points, policies and escalation paths.',
  'Tracking real impact. We separate perceived value from actual business outcomes.',
  'Assessing the next maturity step. When should AI support, augment or be delegated?',
];

const faqItems = faqSchema.mainEntity.map((q) => ({
  question: q.name,
  answer: q.acceptedAnswer.text,
}));

const lastReviewed = 'May 2026';

const caseSteps = [
  {
    label: 'Starting point',
    title: 'High activity, no overview',
    description:
      'An industrial manufacturer had several AI initiatives running across different parts of the business, both in production and administration, each in isolation and without coordination. Leadership had no basis for judging which initiatives were worth backing. Security and data questions were handled differently in every corner, or not at all.',
  },
  {
    label: 'What we did',
    title: 'One shared map',
    description:
      'Every initiative was inventoried and made visible on one shared map. Security and data questions were assessed as an integrated part of the work, not a separate track. Initiatives were evaluated by business value, feasibility and risk in the same motion.',
  },
  {
    label: 'Outcome',
    title: 'From spectator to active governance',
    description:
      'For the first time, leadership had a single decision foundation and moved from passive observer to active steward. They prioritised the right initiatives and put resources behind them. The result was more coordinated activity and visible delivery that lifted quality across several parts of the business, in both production and administration. Security was built in from the start, which gave leadership the confidence to commit rather than hesitate.',
  },
];
---

<PageLayout
  title={metaTitle}
  description={metaDescription}
  ogImage="/og/en/services/ai-fasttrack.png"
  locale={locale}
  headerTheme="dark"
>
  <JsonLd schema={serviceSchema} />
  <JsonLd schema={faqSchema} />
  <JsonLd schema={itemListSchema} />

  <HeroSimple
    title="AI FastTrack — AI Security & Governance"
    description="AI security and governance integrated from decision to model, without losing momentum."
    breadcrumbs={[
      { label: 'Services', href: getServicesPath(locale) },
      { label: 'AI FastTrack' },
    ]}
    bgImage="/images/heroes/services/ai-fasttrack.webp"
    bgImageAlt=""
    locale={locale}
  />

  <!-- Intro & core principle -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="overline mb-4">About the service</p>
        <p class="lead text-slate mb-6">
          Everyone is talking about accelerating AI. We make sure you actually can, without losing control.
          AI FastTrack ties AI security and governance to every decision in the AI lifecycle, so
          leadership ends up with a governable capability instead of a collection of pilots.
        </p>
        <p class="text-gray leading-relaxed mb-4">
          We combine decision mapping, risk analysis, governance model and control framework in one
          coherent delivery. The result is a clear picture of where AI creates the most value, and
          which security measures you need before taking the next step. Requirements from <a href={getServicePath(locale, 'nis2')} class="text-teal-dark underline decoration-teal/30 hover:decoration-teal">NIS2</a>,
          the EU AI Act and GDPR are mapped in from the start, with ISO/IEC 42001 referenced where relevant.
        </p>
        <p class="text-gray leading-relaxed mb-4">
          Built on CISO engagements and <a href={getServicePath(locale, 'risk-management')} class="text-teal-dark underline decoration-teal/30 hover:decoration-teal">risk management</a> work
          with Swedish public-sector organisations and private companies that want AI to pass both the auditor and the workday.
        </p>
        <p class="text-gray leading-relaxed">
          Most organisations run AI linearly: pilot, pause, worry, restart. Every new initiative starts
          from zero with a new risk assessment and new questions for leadership. That's stop-and-go
          driving, and it's why AI feels slow and expensive even though the technology is fast. It's also
          what we call <a href={getInsightPath(locale, 'compliance-cost-governance-debt')} class="text-teal-dark underline decoration-teal/30 hover:decoration-teal">governance debt</a>.
          AI FastTrack removes the stop-and-go. Once initiatives sit on one shared map, prioritised and
          security-assessed, leadership can steer with confidence and each new initiative builds on the
          last. That's where acceleration becomes real — not in one faster step, but in never having to
          back up again.
        </p>
      </div>

      <div class="mt-10 max-w-3xl bg-surface border-l-4 border-teal p-6 lg:p-8" data-reveal>
        <p class="overline mb-2 text-teal-dark">Core principle</p>
        <p class="text-xl lg:text-2xl font-semibold text-navy leading-snug">
          Governance isn't the brake. It's what lets you move fastest — with security on board.
        </p>
        <p class="mt-3 text-sm text-gray italic">Method first. Tools second. Security always.</p>
      </div>
    </div>
  </section>

  <!-- The challenge -->
  <section class="section-sm bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="overline mb-3">The challenge</p>
        <h2>Why AI security and governance belong together</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {challenges.map((c, i) => (
          <div
            class="bg-white rounded-xl border border-border p-6 lg:p-8 relative"
            data-reveal
            data-delay={String(i + 1)}
          >
            <div class="text-4xl font-bold text-navy/10 mb-3 leading-none">
              {String(i + 1).padStart(2, '0')}
            </div>
            <h3 class="text-lg font-semibold text-navy mb-3">{c.title}</h3>
            <p class="text-sm text-gray leading-relaxed">{c.description}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center" data-reveal>
        <p class="inline-block text-sm font-semibold text-accent-dark bg-accent/25 px-4 py-2 rounded-full italic">
          AI ends up as a cost instead of a capability.
        </p>
      </div>
    </div>
  </section>

  <!-- Two packages -->
  <ServicePackages
    packages={packages}
    locale={locale}
    overline="AI FastTrack"
    heading="Two ways into AI governance"
  />

  <!-- Comparison table -->
  <ComparisonTable
    rows={comparisonRows}
    dimensionLabel="Dimension"
    genericLabel="Typical AI consultancy"
    fasttrackLabel="AI FastTrack"
    overline="Comparison"
    heading="AI FastTrack compared with a typical AI consultancy"
    locale={locale}
  />

  <!-- Customer case -->
  <section class="section-sm bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="overline mb-3">Customer case</p>
        <h2>From scattered AI pilots to a coordinated capability</h2>
        <p class="text-gray leading-relaxed mt-4">
          Anonymised industrial customer case. This is what acceleration looks like in practice.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {caseSteps.map((c, i) => (
          <div
            class="bg-white rounded-xl border border-border p-6 lg:p-8 relative"
            data-reveal
            data-delay={String(i + 1)}
          >
            <div class="text-4xl font-bold text-navy/10 mb-3 leading-none">
              {String(i + 1).padStart(2, '0')}
            </div>
            <p class="overline mb-2 text-teal-dark">{c.label}</p>
            <h3 class="text-lg font-semibold text-navy mb-3">{c.title}</h3>
            <p class="text-sm text-gray leading-relaxed">{c.description}</p>
          </div>
        ))}
      </div>

      {/*
        TODO: Activate the customer-quote block below when an attributable quote is available.
        Remove this wrapping comment and fill in quote + role/industry.

        <figure class="mt-10 max-w-3xl mx-auto bg-white border-l-4 border-teal p-6 lg:p-8" data-reveal>
          <blockquote class="text-lg lg:text-xl text-navy leading-snug font-medium">
            "Customer's own words."
          </blockquote>
          <figcaption class="mt-3 text-sm text-gray">
            CIO, Nordic industrial manufacturer
          </figcaption>
        </figure>
      */}
    </div>
  </section>

  <!-- What leadership gets -->
  <section class="section">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="overline mb-3">What you get</p>
        <h2>What leadership gets out of AI FastTrack</h2>
      </div>

      <ul class="grid md:grid-cols-2 gap-6 lg:gap-8">
        {expectations.map((item, i) => (
          <li
            class="flex items-start gap-4 bg-surface rounded-xl border border-border p-5 lg:p-6"
            data-reveal
            data-delay={String((i % 4) + 1)}
          >
            <div class="shrink-0 w-10 h-10 rounded-full bg-teal/15 flex items-center justify-center">
              <svg
                class="w-5 h-5 text-teal-dark"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="text-slate leading-relaxed text-sm lg:text-base pt-1">{item}</p>
          </li>
        ))}
      </ul>

      <p class="mt-10 max-w-3xl text-sm text-gray" data-reveal>
        After delivery we can support implementation through <a href={getServicePath(locale, 'ciso-as-a-service')} class="text-teal-dark underline decoration-teal/30 hover:decoration-teal">CISO-as-a-Service</a> or hand over the roadmap so you can drive the work yourselves.
      </p>
    </div>
  </section>

  <!-- Related services -->
  {relatedServices.length > 0 && (
    <section class="section-sm bg-surface">
      <div class="container">
        <h2 class="mb-10" data-reveal>Related services</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {relatedServices.map((s, i) => (
            <div data-reveal data-delay={String(i + 1)}>
              <ServiceCard
                title={s.data.title}
                description={s.data.excerpt}
                href={getServicePath(locale, s.data.slug)}
                locale={locale}
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="max-w-2xl mb-10" data-reveal>
        <p class="overline mb-3">FAQ</p>
        <h2>Questions leadership teams ask us</h2>
      </div>

      <div class="max-w-3xl space-y-3">
        {faqItems.map((item, i) => (
          <details
            class="group bg-surface border border-border p-5 lg:p-6"
            data-reveal
            data-delay={String((i % 3) + 1)}
          >
            <summary class="flex items-start justify-between gap-4 cursor-pointer list-none font-semibold text-navy">
              <span>{item.question}</span>
              <span class="shrink-0 text-teal-dark text-xl leading-none transition-transform group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="mt-4 text-gray leading-relaxed text-sm lg:text-base">{item.answer}</p>
          </details>
        ))}
      </div>

      <p class="mt-12 text-xs text-gray" data-reveal>
        Last reviewed: {lastReviewed}.
      </p>
    </div>
  </section>

  <CTABanner
    title="Ready for the next step?"
    description="Book a Readiness Assessment. Two to three days that give leadership a decision foundation with both value and security on the map."
    buttonText="Book Readiness Assessment"
    locale={locale}
  />
</PageLayout>
