---
import PageLayout from '@layouts/PageLayout.astro';
import HeroSimple from '@components/sections/HeroSimple.astro';
import Badge from '@components/ui/Badge.astro';
import CTABanner from '@components/sections/CTABanner.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import { site } from '@data/site';
import { getInsightsByLocale } from '@i18n/content';
import { getInsightPath } from '@i18n/routes';
import { formatDate } from '@i18n/index';
import { getReadingTime, formatReadingTime } from '@utils/reading-time';
import { t } from '@i18n/index';

const locale = 'sv';
const insights = await getInsightsByLocale(locale);
const [featured, ...rest] = insights;

const collectionPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Insikter om cybersäkerhet & compliance',
  description: 'Artiklar och analyser om cybersäkerhet, compliance och informationssäkerhet.',
  url: `${site.url}/insikter`,
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Insikter',
  itemListElement: insights.map((post, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `${site.url}${getInsightPath(locale, post.id.replace(`${locale}/`, ''))}`,
    name: post.data.title,
  })),
};
---

<PageLayout title="Insikter om cybersäkerhet & compliance" description="Artiklar och analyser om cybersäkerhet, compliance och informationssäkerhet." ogImage="/og/insikter.png" locale={locale}>
  <JsonLd schema={collectionPageSchema} />
  <JsonLd schema={itemListSchema} />
  <HeroSimple
    title="Insikter"
    description="Artiklar, analyser och praktiska råd inom cybersäkerhet, compliance och informationssäkerhet."
    breadcrumbs={[{ label: 'Insikter' }]}
    locale={locale}
  />

  <section class="section">
    <div class="container">
      {insights.length > 0 ? (
        <>
          {/* Featured article */}
          {featured && (
            <article class="grid lg:grid-cols-5 gap-8 lg:gap-12 mb-16" data-reveal>
              <a href={getInsightPath(locale, featured.id.replace(`${locale}/`, ''))} class="lg:col-span-3 block group">
                <div class="aspect-[16/9] rounded-xl bg-surface overflow-hidden">
                  {featured.data.image ? (
                    <img src={featured.data.image} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  ) : (
                    <div class="w-full h-full bg-gradient-to-br from-navy/5 to-accent/10 group-hover:scale-105 transition-transform duration-500"></div>
                  )}
                </div>
              </a>
              <div class="lg:col-span-2 flex flex-col justify-center">
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-4">
                  <Badge text={featured.data.category} variant="copper" />
                  <time class="text-xs text-gray" datetime={featured.data.date.toISOString()}>
                    {formatDate(featured.data.date, locale)}
                  </time>
                  <span class="text-xs text-gray">&middot; {formatReadingTime(getReadingTime(featured.body || ''), locale)}</span>
                </div>
                <h2 class="text-2xl font-bold text-navy mb-3">
                  <a href={getInsightPath(locale, featured.id.replace(`${locale}/`, ''))} class="hover:text-accent-dark transition-colors">
                    {featured.data.title}
                  </a>
                </h2>
                <p class="text-gray leading-relaxed mb-5">{featured.data.description}</p>
                <a href={getInsightPath(locale, featured.id.replace(`${locale}/`, ''))} class="text-sm font-medium text-accent-dark hover:underline underline-offset-2">
                  {t(locale, 'insightDetail.readArticle')} &rarr;
                </a>
              </div>
            </article>
          )}

          {/* Remaining articles */}
          {rest.length > 0 && (
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
              {rest.map((post, i) => (
                <article class="group" data-reveal data-delay={String((i % 3) + 1)}>
                  <a href={getInsightPath(locale, post.id.replace(`${locale}/`, ''))} class="block">
                    <div class="aspect-[16/9] rounded-xl bg-surface mb-5 overflow-hidden">
                      {post.data.image ? (
                        <img src={post.data.image} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                      ) : (
                        <div class="w-full h-full bg-gradient-to-br from-navy/5 to-accent/5 group-hover:scale-105 transition-transform duration-500"></div>
                      )}
                    </div>
                    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-3">
                      <Badge text={post.data.category} variant="copper" />
                      <time class="text-xs text-gray" datetime={post.data.date.toISOString()}>
                        {formatDate(post.data.date, locale)}
                      </time>
                      <span class="text-xs text-gray">&middot; {formatReadingTime(getReadingTime(post.body || ''), locale)}</span>
                    </div>
                    <h3 class="text-lg font-semibold text-navy group-hover:text-accent-dark transition-colors mb-2">
                      {post.data.title}
                    </h3>
                    <p class="text-sm text-gray leading-relaxed">{post.data.description}</p>
                  </a>
                </article>
              ))}
            </div>
          )}
        </>
      ) : (
        <p class="text-center text-gray">Inga insikter publicerade ännu.</p>
      )}
    </div>
  </section>

  <!-- Kommuner -->
  <section class="section-sm bg-surface">
    <div class="container">
      <a href="/insikter/kommuner" class="grid lg:grid-cols-5 gap-8 items-center group" data-reveal>
        <div class="lg:col-span-3">
          <p class="overline mb-3">Per kommun</p>
          <h2 class="mb-3 group-hover:text-accent-dark transition-colors">Cybersäkerhet & NIS2 per kommun</h2>
          <p class="text-gray leading-relaxed">Cybersäkerhetslagen berör alla Sveriges 290 kommuner. Hitta din kommun och se vilka verksamheter som berörs och hur vi kan hjälpa.</p>
        </div>
        <div class="lg:col-span-2 flex justify-end">
          <span class="inline-flex items-center gap-2 text-sm font-medium text-accent-dark group-hover:gap-3 transition-all">
            Se alla kommuner
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </span>
        </div>
      </a>
    </div>
  </section>

  <CTABanner locale={locale} />
</PageLayout>
