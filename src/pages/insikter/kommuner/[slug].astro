---
import PageLayout from '@layouts/PageLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import Button from '@components/ui/Button.astro';
import CTABanner from '@components/sections/CTABanner.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import SwedenMap from '@components/ui/SwedenMap.astro';
import { site, organizationSchema } from '@data/site';
import {
  kommuner,
  getKommunMetaTitle,
  getKommunMetaDescription,
  getKommunFaq,
  getSectorLabel,
  getKommunIntro,
  getKommunItSecurity,
  getKommunCallout,
  getKommunLocalLead,
  getKommunHelpIntro,
  getKommunSteps,
  getKommunSectorIntro,
  getKommunCtaText,
  getNeighbours,
} from '@data/kommuner';
import type { Kommun } from '@data/kommuner';
import {
  getContactPath,
  getSecurapilotPath,
  getServicePath,
  getKommunPath,
} from '@i18n/routes';

const locale = 'sv';

export async function getStaticPaths() {
  return kommuner.map((k) => ({
    params: { slug: k.slug },
    props: { kommun: k },
  }));
}

const { kommun } = Astro.props as { kommun: Kommun };

const metaTitle = getKommunMetaTitle(kommun);
const metaDescription = getKommunMetaDescription(kommun);
const faq = getKommunFaq(kommun);

const localServiceSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: `Verit, Cybersäkerhet & NIS2 i ${kommun.name}`,
  description: metaDescription,
  url: `${site.url}/insikter/kommuner/${kommun.slug}`,
  provider: {
    '@type': 'Organization',
    name: organizationSchema.name,
    url: organizationSchema.url,
    address: organizationSchema.address,
    telephone: organizationSchema.telephone,
  },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: kommun.name,
    containedInPlace: {
      '@type': 'State',
      name: kommun.county,
      addressCountry: 'SE',
    },
  },
  serviceType: 'Cybersäkerhetskonsulting',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Cybersäkerhetstjänster',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'NIS2-rådgivning' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'ISO 27001' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'CISO-as-a-Service' } },
    ],
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};

const typeIntro = getKommunIntro(kommun);
const itSecurity = getKommunItSecurity(kommun);
const typeCallout = getKommunCallout(kommun);
const localLead = getKommunLocalLead(kommun);
const helpIntro = getKommunHelpIntro(kommun);
const steps = getKommunSteps(kommun);
const sectorIntro = getKommunSectorIntro(kommun);
const ctaText = getKommunCtaText(kommun);
const neighbours = getNeighbours(kommun, 4);
const typeImage = `/images/kommuner/${kommun.type}.webp`;
const heroImage = `/images/kommuner/hero-${kommun.type}.webp`;

// Contextual links to the most relevant services — gives every service page
// up to ~290 internal links, a strong crawl-priority signal.
const relatedServices = [
  { slug: 'nis2', label: 'NIS2-efterlevnad' },
  { slug: 'iso27001', label: 'ISO 27001' },
  { slug: 'ciso-as-a-service', label: 'CISO-as-a-Service' },
  { slug: 'riskhantering', label: 'Riskhantering' },
  { slug: 'gdpr', label: 'GDPR & dataskydd' },
  { slug: 'utbildning', label: 'Utbildning & awareness' },
];
---

<PageLayout title={metaTitle} description={metaDescription} ogImage={`/og/insikter/kommuner/${kommun.slug}.png`} locale={locale} svOnly={true} headerTheme="dark">
  <JsonLd schema={localServiceSchema} />
  <JsonLd schema={faqSchema} />
  <!-- Hero with background image -->
  <section class="relative -mt-20 pt-32 pb-20 overflow-hidden">
    <img
      src={heroImage}
      alt=""
      width="1920"
      height="1072"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-navy-dark/75"></div>
    <div class="container relative z-10">
      <div class="hero-breadcrumb">
        <Breadcrumb items={[{ label: 'Insikter', href: '/insikter' }, { label: 'Kommuner', href: '/insikter/kommuner' }, { label: kommun.name }]} locale={locale} />
      </div>
      <div class="max-w-3xl mt-6" data-reveal>
        <h1 class="text-white">{`Cybersäkerhet och NIS2 i ${kommun.name}`}</h1>
        <p class="lead mt-4 text-white/70">{`Uppskattningsvis ${kommun.nis2Estimate} organisationer i ${kommun.name} berörs av cybersäkerhetslagen. Vi hjälper företag och kommun att komma igång, pragmatiskt och steg för steg.`}</p>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section">
    <div class="container">
      <div class="grid lg:grid-cols-5 gap-12">
        <div class="lg:col-span-3" data-reveal>
          <p class="overline mb-4">Cybersäkerhet i {kommun.name}</p>
          <p class="text-lg text-slate leading-relaxed mb-6">{typeIntro}</p>
          <p class="text-gray leading-relaxed mb-4">{localLead.angle}</p>
          {localLead.employers && <p class="text-gray leading-relaxed mb-6">{localLead.employers}</p>}
          <div class="grid sm:grid-cols-3 gap-4">
            <div class="bg-surface rounded-lg p-5 border border-border text-center">
              <span class="block text-2xl font-bold text-navy">{kommun.population.toLocaleString('sv-SE')}</span>
              <span class="text-sm text-gray">Invånare</span>
            </div>
            <div class="bg-surface rounded-lg p-5 border border-border text-center">
              <span class="block text-2xl font-bold text-accent-dark">~{kommun.nis2Estimate}</span>
              <span class="text-sm text-gray">NIS2-berörda organisationer</span>
            </div>
            <div class="bg-surface rounded-lg p-5 border border-border text-center">
              <span class="block text-2xl font-bold text-navy">{kommun.county}</span>
              <span class="text-sm text-gray">Län</span>
            </div>
          </div>
        </div>
        <div class="lg:col-span-2" data-reveal="right">
          <div class="lg:sticky" style="top: 2px;">
            <SwedenMap name={kommun.name} lat={kommun.lat} lng={kommun.lng} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- IT- och datasäkerhet (broadens coverage for IT-/data-/nätverkssäkerhet {stad} queries) -->
  <section class="section-sm">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="overline mb-3">IT- & datasäkerhet</p>
        <h2 class="mb-4">{itSecurity.heading}</h2>
        <p class="text-gray leading-relaxed">{itSecurity.body}</p>
      </div>
    </div>
  </section>

  <!-- NIS2-berörda sektorer -->
  <section class="section-sm bg-surface">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="overline mb-3">Berörda sektorer</p>
        <h2 class="mb-6">Vilka berörs i {kommun.name}?</h2>
        <p class="text-gray leading-relaxed mb-6">{sectorIntro}</p>
        <div class="grid sm:grid-cols-2 gap-3 mb-8">
          {kommun.dominantSectors.map((sector) => (
            <div class="flex items-center gap-3 bg-white rounded-lg px-5 py-4 border border-border">
              <div class="w-2 h-2 rounded-full bg-teal shrink-0"></div>
              <span class="text-sm font-medium text-navy">{getSectorLabel(sector)}</span>
            </div>
          ))}
        </div>
        <div class="bg-white rounded-lg p-5 border border-border">
          <h3 class="text-sm font-semibold text-navy mb-2">Tillsynsmyndigheter</h3>
          <p class="text-sm text-gray">
            Verksamheter i {kommun.name} övervakas beroende på sektor av: {kommun.tillsynsmyndigheter.join(', ')}. Kommunen som offentlig förvaltning hör under Länsstyrelsen i {kommun.county}s län.
          </p>
        </div>
        <div class="mt-8">
          <Button href={getContactPath(locale)} variant="primary" size="md">
            Boka ett kostnadsfritt möte
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Type-specific callout -->
  <section class="bg-navy-dark relative overflow-hidden">
    <img
      src={typeImage}
      alt=""
      width="1920"
      height="1280"
      class="absolute inset-0 w-full h-full object-cover opacity-40"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-dark/90 via-navy-dark/70 to-navy-dark/50"></div>
    <div class="container section relative z-10">
      <div class="max-w-3xl" data-reveal>
        <h2 class="text-white mb-4">{typeCallout.title}</h2>
        <p class="text-lg text-white/60 leading-relaxed">{typeCallout.text}</p>
      </div>
    </div>
  </section>

  <!-- How we help -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="overline mb-3">Så kan vi hjälpa</p>
        <h2 class="mb-4">Pragmatiskt stöd, anpassat efter er verklighet</h2>
        <p class="text-gray leading-relaxed mb-8">{helpIntro}</p>
        <div class="space-y-6">
          {steps.map((step) => (
            <div class="flex gap-4">
              <div class="shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-navy text-white font-bold">{step.num}</div>
              <div class="pt-0.5">
                <h3 class="font-semibold text-navy mb-1">{step.title}</h3>
                <p class="text-sm text-gray">{step.text}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="mt-10 pt-8 border-t border-border">
          <h3 class="text-sm font-semibold text-navy mb-4">Tjänster som är relevanta för verksamheter i {kommun.name}</h3>
          <div class="flex flex-wrap gap-2">
            {relatedServices.map((s) => (
              <a
                href={getServicePath(locale, s.slug)}
                class="inline-flex items-center rounded-full border border-border bg-white px-4 py-2 text-sm font-medium text-navy hover:border-teal hover:text-teal transition-colors"
              >
                {s.label}
              </a>
            ))}
          </div>
        </div>
        <div class="flex flex-wrap gap-4 mt-8">
          <Button href={getContactPath(locale)} variant="primary" size="md">
            Boka ett kostnadsfritt möte
          </Button>
          <Button href={getSecurapilotPath(locale)} variant="ghost" size="md">
            Se hur Securapilot fungerar
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-sm bg-surface">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="overline mb-3">Vanliga frågor</p>
        <h2 class="mb-8">NIS2 och cybersäkerhet i {kommun.name}</h2>
        <div class="space-y-3">
          {faq.map((item) => (
            <details class="group bg-white rounded-lg border border-border">
              <summary class="flex items-center justify-between px-5 py-4 cursor-pointer text-navy font-medium text-sm">
                {item.question}
                <svg class="w-5 h-5 text-gray shrink-0 ml-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-5 pb-4 text-sm text-gray leading-relaxed">
                {item.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  {neighbours.length > 0 && (
    <section class="section-sm">
      <div class="container">
        <div class="max-w-3xl" data-reveal>
          <p class="overline mb-3">Närliggande kommuner</p>
          <h2 class="mb-6">Cybersäkerhet och NIS2 i grannkommunerna</h2>
          <p class="text-gray leading-relaxed mb-6">
            Vi arbetar i hela {kommun.county} och omkringliggande län. Se hur cybersäkerhetslagen berör verksamheter i kommuner nära {kommun.name}:
          </p>
          <div class="flex flex-wrap gap-2">
            {neighbours.map((n) => (
              <a
                href={getKommunPath(n.slug)}
                class="inline-flex items-center rounded-full border border-border bg-white px-4 py-2 text-sm font-medium text-navy hover:border-teal hover:text-teal transition-colors"
              >
                {n.name}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <CTABanner
    title={`Behöver ni hjälp med cybersäkerhet i ${kommun.name}?`}
    description={ctaText}
    locale={locale}
  />
</PageLayout>

<style>
  .hero-breadcrumb :global(ol) {
    color: rgba(255, 255, 255, 0.6);
  }
  .hero-breadcrumb :global(a) {
    color: rgba(255, 255, 255, 0.6);
  }
  .hero-breadcrumb :global(a:hover) {
    color: white;
  }
  .hero-breadcrumb :global(span) {
    color: white;
  }
  .hero-breadcrumb :global(svg) {
    color: rgba(255, 255, 255, 0.4);
  }
</style>
