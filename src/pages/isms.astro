---
import PageLayout from '@layouts/PageLayout.astro';
import HeroSimple from '@components/sections/HeroSimple.astro';
import Button from '@components/ui/Button.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import { site, organizationSchema } from '@data/site';
import { getServicePath, getInsightPath } from '@i18n/routes';

const locale = 'sv' as const;

const metaTitle = 'ISMS-system: Securapilot — ledningssystem för informationssäkerhet | Verit';
const metaDescription =
  'Securapilot är ISMS-plattformen som tar ert ledningssystem för informationssäkerhet från Excel till levande arbetssätt. ISO 27001, NIS2 och GDPR mappade i ett system.';

const pageUrl = `${site.url}/isms`;

// UTM-helper för spårning i Securapilots analytics
const utm = (content: string, path = '') =>
  `https://securapilot.com${path}?utm_source=verit&utm_medium=referral&utm_campaign=isms-landing&utm_content=${content}`;

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'ISMS — ISMS-system, ISMS-plattform och Securapilot',
  description: metaDescription,
  url: pageUrl,
  inLanguage: 'sv-SE',
  isPartOf: {
    '@type': 'WebSite',
    name: organizationSchema.name,
    url: organizationSchema.url,
  },
  about: {
    '@type': 'Thing',
    name: 'Information Security Management System (ISMS)',
    sameAs: 'https://en.wikipedia.org/wiki/ISO/IEC_27001',
  },
};

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Securapilot',
  applicationCategory: 'BusinessApplication',
  applicationSubCategory: 'ISMS (Information Security Management System)',
  operatingSystem: 'Web',
  url: 'https://securapilot.com',
  description:
    'Securapilot är en ISMS-plattform som operationaliserar ledningssystem för informationssäkerhet. Den mappar kontroller mot ISO 27001, NIS2/cybersäkerhetslagen, GDPR och andra ramverk i ett system, med inbyggd granskningsspår och riskregister.',
  provider: {
    '@type': 'Organization',
    name: organizationSchema.name,
    url: organizationSchema.url,
  },
  offers: {
    '@type': 'Offer',
    url: 'https://securapilot.com/priser/',
    priceCurrency: 'SEK',
    availability: 'https://schema.org/InStock',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Vad är ett ISMS?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ett ISMS (Information Security Management System), på svenska LIS (ledningssystem för informationssäkerhet), är inte ett system i datorbemärkelse. Det är ett sätt att organisera arbetet med informationssäkerhet så att det är spårbart, mätbart och kan förbättras över tid. Det består av policyer, processer, roller, kontroller och ett kontinuerligt förbättringsarbete.',
      },
    },
    {
      '@type': 'Question',
      name: 'Vad är skillnaden mellan ISMS och ISO 27001?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ett ISMS är sättet ni jobbar med informationssäkerhet. ISO 27001 är den internationella standarden som definierar vad ett bra ISMS innehåller. Man kan ha ett ISMS utan ISO 27001-certifiering, men ISO 27001 ger ramverket som de flesta organisationer utgår från.',
      },
    },
    {
      '@type': 'Question',
      name: 'Behöver vi ett ISMS för att efterleva NIS2 eller cybersäkerhetslagen?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ja, i praktiken. Cybersäkerhetslagen (som genomför NIS2 i Sverige) kräver strukturerad och spårbar säkerhet på lednings- och driftnivå. Det är precis vad ett ISMS levererar. Utan ISMS blir efterlevnaden adhoc och svår att visa upp vid tillsyn.',
      },
    },
    {
      '@type': 'Question',
      name: 'Kan vi ha ett ISMS i Excel?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Tekniskt sett ja, men det skalar sällan över tid. Excel-baserade ISMS fungerar tills organisationen växer, flera regelverk ska hanteras parallellt, eller granskaren ställer frågor som kräver spårbarhet. Då blir bristen på versioner, ägarskap och tidsstämplar plötsligt synlig. Ett ISMS-system löser detta.',
      },
    },
    {
      '@type': 'Question',
      name: 'Vad kostar ett ISMS-system?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Priset beror på organisationens storlek och behov. Securapilot publicerar sina priser öppet på securapilot.com/priser. För enklare jämförelser är prisspannet jämförbart med ett medelstort affärssystem och betydligt lägre än kostnaden för manuellt ISMS-arbete över tid.',
      },
    },
    {
      '@type': 'Question',
      name: 'Hur långt tid tar det att införa ett ISMS?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Med en plattform kan grundläggande riskregister och kontrollmappning vara på plats inom dagar. Att bygga ett moget ISMS som klarar ISO 27001-certifiering tar ofta 4–8 månader beroende på utgångsläge. Skillnaden mot Excel-spår är att plattformen accelererar både införandet och det löpande arbetet.',
      },
    },
    {
      '@type': 'Question',
      name: 'Vad är ett ISMS-system?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ett ISMS-system (eller ISMS-plattform) är mjukvaran som operationaliserar ert ISMS. Det innehåller typiskt riskregister, kontrollramverk, dokumenthantering, gap-analyser, incidenthantering och granskningsspår. Det ersätter Excel- och Word-baserat arbete med en strukturerad plattform där allt är versionerat och spårbart.',
      },
    },
    {
      '@type': 'Question',
      name: 'Är ISMS samma sak som LIS?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ja. LIS (ledningssystem för informationssäkerhet) är den svenska översättningen av ISMS (Information Security Management System). Begreppen används synonymt — myndigheter och svensk lagtext säger oftare LIS, internationell standard och leverantörer säger oftare ISMS.',
      },
    },
  ],
};

const faqItems = faqSchema.mainEntity.map((q) => ({
  question: q.name,
  answer: q.acceptedAnswer.text,
}));

const reasons = [
  {
    title: 'Spårbarhet under granskning',
    description:
      'När tillsynsmyndigheten frågar vem som godkände vad och på vilka grunder, behöver svaret finnas på sekunden. Ett ISMS-system tidsstämplar och versionerar varje beslut, så ni inte letar i mappar inför audit.',
  },
  {
    title: 'Flera regelverk samtidigt',
    description:
      'ISO 27001, NIS2/cybersäkerhetslagen, GDPR och DORA överlappar i kontroller. Utan plattform betalas samma arbete flera gånger. En kontroll som mappar till alla regelverk samtidigt — det är där tidsbesparingen ligger.',
  },
  {
    title: 'Levande process istället för revisionsrush',
    description:
      'Ett ISMS som lever året om kräver inte panikinsats inför granskning. Dokumentationen är redan på plats, kontrollerna är redan utförda, riskerna är redan hanterade.',
  },
];

const capabilities = [
  {
    title: 'Riskregister',
    description: 'Med ägarskap, åtgärder och spårbarhet. Risker accepteras av rätt person, dokumenterat med tidsstämpel.',
  },
  {
    title: 'Kontrollramverk',
    description: 'Mappade mot ISO 27001, NIS2/cybersäkerhetslagen, GDPR och DORA samtidigt. En kontroll täcker flera regelverk.',
  },
  {
    title: 'Dokumenthantering',
    description: 'Versioner, ägare och giltighetsdatum. Inget mer "vilken är senaste policyn?"-letande.',
  },
  {
    title: 'Gap-analyser',
    description: 'Som bygger upp över tid, inte engångsmoment. Mognaden blir mätbar och synlig.',
  },
  {
    title: 'Incidenthantering',
    description: 'Kopplad till åtgärder och rapporteringskrav. NIS2-incidentrapportering blir spårbar från första klick.',
  },
  {
    title: 'Granskningsspår',
    description: 'Klart för revisor — inte i pärm utan i tidsstämpel. Klickbart från första frågan.',
  },
];

const securapilotFeatures = [
  {
    title: 'Färdiga ramverksmappningar',
    description: 'ISO 27001, NIS2/cybersäkerhetslagen, GDPR och DORA. En kontroll, flera regelverk täckta.',
  },
  {
    title: 'Levande riskregister',
    description: 'Inte ett dokument. En process. Risker har ägare, åtgärder och spårbar beslutsväg.',
  },
  {
    title: 'Auditspår från dag ett',
    description: 'Allt som händer i plattformen sparas med tidsstämpel. Granskningsfrågor besvaras på sekunder.',
  },
  {
    title: 'Svensk lagstiftning inbyggd',
    description: 'Cybersäkerhetslagen och svenska tillsynsmyndigheters krav är integrerade — inte ett tillägg.',
  },
];

const audiences = [
  {
    title: 'CISO:er som ärvt ett pappers-ISMS',
    description: 'Pärmen finns. Innehållet är delvis sant. Plattformen ger struktur ovanpå det ni har, utan att börja om.',
  },
  {
    title: 'IT-chefer i kommuner',
    description: 'Som ska efterleva cybersäkerhetslagen och behöver visa upp ett strukturerat säkerhetsarbete vid tillsyn.',
  },
  {
    title: 'Informationssäkerhetssamordnare',
    description: 'Som [sitter ensamma med ansvaret](/insikter/ensam-om-ansvaret) och behöver ett verktyg som inte kräver fem timmar manuellt arbete per vecka.',
  },
  {
    title: 'Verksamheter inför ISO 27001-certifiering',
    description: 'Som vill bygga ett ISMS rätt från början istället för att samla dokument i Word.',
  },
  {
    title: 'Bolag med flera regelverk',
    description: 'ISO 27001 + NIS2 + GDPR + DORA. Utan plattform betalas samma arbete flera gånger.',
  },
];

const lastReviewed = 'juni 2026';
---

<PageLayout
  title={metaTitle}
  description={metaDescription}
  ogImage="/og/isms.png"
  locale={locale}
  headerTheme="dark"
  svOnly={true}
>
  <JsonLd schema={webPageSchema} />
  <JsonLd schema={softwareSchema} />
  <JsonLd schema={faqSchema} />

  <HeroSimple
    title="ISMS som ert team faktiskt vill använda"
    description="Securapilot är ISMS-plattformen som tar ert ledningssystem för informationssäkerhet från Excel-spårning till levande arbetssätt. Mappa ISO 27001, NIS2 och GDPR i ett system. Ingen pärm. Ingen revisionsrush."
    breadcrumbs={[{ label: 'ISMS' }]}
    bgImage="/images/heroes/isms.webp"
    bgImageAlt=""
    locale={locale}
  />

  <!-- Hero CTAs (placerade i en egen sektion direkt efter hero) -->
  <section class="bg-navy-dark relative -mt-1 pb-12">
    <div class="container">
      <div class="flex flex-wrap gap-4" data-reveal>
        <Button
          href={utm('hero-primary')}
          variant="primary"
          size="lg"
          target="_blank"
          rel="noopener"
        >
          Se Securapilot →
        </Button>
        <Button
          href={utm('hero-secondary', '/pilot/')}
          variant="white"
          size="lg"
          target="_blank"
          rel="noopener"
        >
          Starta pilot →
        </Button>
      </div>
    </div>
  </section>

  <!-- Vad är ett ISMS? (educational, SEO-foundational) -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="overline mb-4">Grunderna</p>
        <h2>Vad är ett ISMS?</h2>
        <p class="lead text-slate mt-4 mb-6">
          Ett informationssäkerhetsledningssystem (ISMS, även LIS på svenska) är inte ett system i datorbemärkelse. Det är ett sätt att organisera arbetet med informationssäkerhet så att det är spårbart, mätbart och kan förbättras över tid.
        </p>
        <p class="text-gray leading-relaxed mb-4">
          Ett ISMS består av policyer, processer, roller, kontroller och ett kontinuerligt förbättringsarbete. Det handlar om <em>hur</em> ni jobbar med säkerhet — inte vilka verktyg ni använder. ISO 27001 är den internationella standarden som beskriver vad ett bra ISMS innehåller, men man kan ha ett ISMS utan att vara certifierad.
        </p>
        <p class="text-gray leading-relaxed mb-4">
          I Sverige används termerna ISMS och LIS synonymt. Myndigheter och svensk lagtext säger oftare LIS, medan internationell standard och plattformsleverantörer säger ISMS. Bägge betyder samma sak.
        </p>
        <p class="text-gray leading-relaxed">
          Men ISMS i Word, Excel och delade mappar slutar fungera när organisationen växer eller granskaren ställer frågor. Då behövs ett ISMS-system — en plattform som operationaliserar arbetet och gör det spårbart från dag ett.
        </p>
      </div>
    </div>
  </section>

  <!-- Varför ett ISMS-system? -->
  <section class="section-sm bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="overline mb-3">Problemställning</p>
        <h2>Varför behövs ett ISMS-system?</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {reasons.map((r, i) => (
          <div
            class="bg-white rounded-xl border border-border p-6 lg:p-8 relative"
            data-reveal
            data-delay={String(i + 1)}
          >
            <div class="text-4xl font-bold text-navy/10 mb-3 leading-none">
              {String(i + 1).padStart(2, '0')}
            </div>
            <h3 class="text-lg font-semibold text-navy mb-3">{r.title}</h3>
            <p class="text-sm text-gray leading-relaxed">{r.description}</p>
          </div>
        ))}
      </div>

      <figure class="mt-10 max-w-3xl mx-auto bg-white border-l-4 border-teal p-6 lg:p-8" data-reveal>
        <blockquote class="text-lg lg:text-xl text-navy leading-snug font-medium italic">
          "Ett ISMS i Excel är en fryst ögonblicksbild. Världen står inte still."
        </blockquote>
        <figcaption class="mt-3 text-sm text-gray">
          Från <a href={getInsightPath(locale, 'proportionalitet-ar-farskvara')} class="text-teal-dark underline decoration-teal/30 hover:decoration-teal">Proportionalitet är färskvara</a>
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- Capabilities: vad ett bra ISMS-system gör -->
  <section class="section">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="overline mb-3">Funktionalitet</p>
        <h2>Vad ett bra ISMS-system gör</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {capabilities.map((c, i) => (
          <div
            class="bg-surface rounded-xl border border-border p-6"
            data-reveal
            data-delay={String((i % 3) + 1)}
          >
            <h3 class="text-base font-semibold text-navy mb-2">{c.title}</h3>
            <p class="text-sm text-gray leading-relaxed">{c.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Securapilot som ISMS-plattform (kommersiell pivot) -->
  <section class="section-sm bg-navy-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, rgba(201,122,53,0.3) 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    <div class="container relative z-10">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="overline mb-3 text-accent">Plattformen</p>
        <h2 class="text-white">Securapilot som ISMS-plattform</h2>
        <p class="lead text-white/70 mt-4">
          Securapilot är byggt för svenska organisationer som behöver ett ISMS som lever — inte ett dokument som åldras. Det är ISMS-plattformen som gör arbetet spårbart från första klicket.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-10">
        {securapilotFeatures.map((f, i) => (
          <div
            class="bg-white/5 rounded-xl border border-white/10 p-6 lg:p-8"
            data-reveal
            data-delay={String((i % 4) + 1)}
          >
            <h3 class="text-lg font-semibold text-white mb-2">{f.title}</h3>
            <p class="text-sm text-white/70 leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>

      <div class="flex flex-wrap gap-4" data-reveal>
        <Button
          href={utm('mid-primary', '/pilot/')}
          variant="primary"
          size="lg"
          target="_blank"
          rel="noopener"
        >
          Boka demo på securapilot.com →
        </Button>
        <Button
          href={utm('mid-secondary', '/priser/')}
          variant="white"
          size="lg"
          target="_blank"
          rel="noopener"
        >
          Se priser →
        </Button>
      </div>

      <p class="mt-6 text-xs text-white/50" data-reveal>
        Länkarna går till securapilot.com — vår SaaS-plattform.
      </p>
    </div>
  </section>

  <!-- ISMS vs ISO 27001 vs NIS2 (clarification) -->
  <section class="section">
    <div class="container">
      <div class="max-w-2xl mb-10" data-reveal>
        <p class="overline mb-3">Begreppen</p>
        <h2>ISMS, ISO 27001 och NIS2 — vad är skillnaden?</h2>
        <p class="text-gray leading-relaxed mt-4">
          Tre begrepp som ofta blandas ihop. Det här rensar förvirringen.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-surface rounded-xl border border-border p-6 lg:p-8" data-reveal data-delay="1">
          <p class="overline mb-3 text-teal-dark">Arbetssätt</p>
          <h3 class="text-lg font-semibold text-navy mb-3">ISMS / LIS</h3>
          <p class="text-sm text-gray leading-relaxed">
            Sättet ni arbetar. Policyer, processer, roller och kontroller som tillsammans utgör ert ledningssystem för informationssäkerhet.
          </p>
        </div>
        <div class="bg-surface rounded-xl border border-border p-6 lg:p-8" data-reveal data-delay="2">
          <p class="overline mb-3 text-teal-dark">Standard</p>
          <h3 class="text-lg font-semibold text-navy mb-3">ISO 27001</h3>
          <p class="text-sm text-gray leading-relaxed">
            Den internationella standarden som definierar vad ett bra ISMS innehåller. Ger ramverket — och möjligheten till certifiering.
          </p>
        </div>
        <div class="bg-surface rounded-xl border border-border p-6 lg:p-8" data-reveal data-delay="3">
          <p class="overline mb-3 text-teal-dark">Lag</p>
          <h3 class="text-lg font-semibold text-navy mb-3">NIS2 / cybersäkerhetslagen</h3>
          <p class="text-sm text-gray leading-relaxed">
            Lagen som kräver att ni har strukturerad och spårbar säkerhet. ISMS är hur ni efterlever den.
          </p>
        </div>
      </div>

      <p class="mt-10 max-w-3xl text-base font-semibold text-navy leading-snug" data-reveal>
        Ni behöver ett ISMS. ISO 27001 ger er ramverket. NIS2 gör arbetet obligatoriskt. <a href={utm('inline-cta')} target="_blank" rel="noopener" class="text-teal-dark underline decoration-teal/30 hover:decoration-teal">Securapilot</a> gör det praktiskt.
      </p>

      <p class="mt-4 max-w-3xl text-sm text-gray" data-reveal>
        Vill ni ha konsulthjälp att bygga grundstrukturen först? Se <a href={getServicePath(locale, 'iso27001')} class="text-teal-dark underline decoration-teal/30 hover:decoration-teal">ISO 27001-tjänsten</a> eller <a href={getServicePath(locale, 'nis2')} class="text-teal-dark underline decoration-teal/30 hover:decoration-teal">NIS2-tjänsten</a>.
      </p>
    </div>
  </section>

  <!-- Comparison: Excel vs Securapilot -->
  <section class="section-sm bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-10" data-reveal>
        <p class="overline mb-3">Jämförelse</p>
        <h2>ISMS i Excel jämfört med en ISMS-plattform</h2>
      </div>

      <div class="overflow-x-auto" data-reveal>
        <table class="w-full bg-white rounded-xl border border-border overflow-hidden">
          <thead class="bg-navy-dark text-white">
            <tr>
              <th class="text-left p-4 lg:p-5 text-sm font-semibold">Dimension</th>
              <th class="text-left p-4 lg:p-5 text-sm font-semibold">Excel + Word</th>
              <th class="text-left p-4 lg:p-5 text-sm font-semibold text-accent">Securapilot</th>
            </tr>
          </thead>
          <tbody class="text-sm text-gray">
            <tr class="border-t border-border">
              <td class="p-4 lg:p-5 font-medium text-navy">Spårbarhet</td>
              <td class="p-4 lg:p-5">Beror på vem som sparade senast</td>
              <td class="p-4 lg:p-5 text-navy">Tidsstämplat och versionerat</td>
            </tr>
            <tr class="border-t border-border">
              <td class="p-4 lg:p-5 font-medium text-navy">Granskningssvar</td>
              <td class="p-4 lg:p-5">Letar i mappar</td>
              <td class="p-4 lg:p-5 text-navy">Klickbart från första frågan</td>
            </tr>
            <tr class="border-t border-border">
              <td class="p-4 lg:p-5 font-medium text-navy">Multi-regelverk</td>
              <td class="p-4 lg:p-5">Dubbelarbete för ISO 27001 + NIS2 + GDPR</td>
              <td class="p-4 lg:p-5 text-navy">En kontroll mappar till flera regelverk</td>
            </tr>
            <tr class="border-t border-border">
              <td class="p-4 lg:p-5 font-medium text-navy">Underhåll</td>
              <td class="p-4 lg:p-5">Eldsjäl + tur</td>
              <td class="p-4 lg:p-5 text-navy">Inbyggd i processen</td>
            </tr>
            <tr class="border-t border-border">
              <td class="p-4 lg:p-5 font-medium text-navy">Skalbarhet</td>
              <td class="p-4 lg:p-5">Bryts vid 50 dokument</td>
              <td class="p-4 lg:p-5 text-navy">Skalar med organisationen</td>
            </tr>
            <tr class="border-t border-border">
              <td class="p-4 lg:p-5 font-medium text-navy">Värdet över tid</td>
              <td class="p-4 lg:p-5">Sjunker när dokumenten åldras</td>
              <td class="p-4 lg:p-5 text-navy">Stiger när mognaden växer</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Vem är detta för? -->
  <section class="section">
    <div class="container">
      <div class="max-w-2xl mb-12" data-reveal>
        <p class="overline mb-3">Målgrupp</p>
        <h2>Vem är ett ISMS-system till för?</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {audiences.map((a, i) => (
          <div
            class="bg-surface rounded-xl border border-border p-6 lg:p-8"
            data-reveal
            data-delay={String((i % 4) + 1)}
          >
            <h3 class="text-base font-semibold text-navy mb-2">{a.title}</h3>
            <p class="text-sm text-gray leading-relaxed" set:html={a.description.replace(
              /\[([^\]]+)\]\(([^)]+)\)/g,
              '<a href="$2" class="text-teal-dark underline decoration-teal/30 hover:decoration-teal">$1</a>'
            )} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-sm bg-surface">
    <div class="container">
      <div class="max-w-2xl mb-10" data-reveal>
        <p class="overline mb-3">Vanliga frågor</p>
        <h2>Frågor om ISMS och ISMS-system</h2>
      </div>

      <div class="max-w-3xl space-y-3">
        {faqItems.map((item, i) => (
          <details
            class="group bg-white border border-border p-5 lg:p-6"
            data-reveal
            data-delay={String((i % 3) + 1)}
          >
            <summary class="flex items-start justify-between gap-4 cursor-pointer list-none font-semibold text-navy">
              <span>{item.question}</span>
              <span class="shrink-0 text-teal-dark text-xl leading-none transition-transform group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="mt-4 text-gray leading-relaxed text-sm lg:text-base">{item.answer}</p>
          </details>
        ))}
      </div>

      <p class="mt-12 text-xs text-gray" data-reveal>
        Senast uppdaterad: {lastReviewed}.
      </p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-navy-dark relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, rgba(201,122,53,0.3) 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    <div class="container section-sm relative z-10">
      <div class="max-w-2xl mx-auto text-center" data-reveal>
        <h2 class="text-white mb-4">Se Securapilot — ISMS-plattformen för svenska organisationer</h2>
        <p class="lead text-white/60 mb-8">
          Ta ert ISMS från Excel till levande arbetssätt. ISO 27001, NIS2 och GDPR i samma system, byggt för svensk lagstiftning.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <Button
            href={utm('footer-primary')}
            variant="primary"
            size="lg"
            target="_blank"
            rel="noopener"
          >
            Besök securapilot.com →
          </Button>
          <Button
            href={utm('footer-secondary', '/pilot/')}
            variant="white"
            size="lg"
            target="_blank"
            rel="noopener"
          >
            Starta pilot →
          </Button>
        </div>
        <p class="mt-8 text-sm text-white/50">
          Vill ni ha konsulthjälp att bygga ert ISMS först?
          <a href={getServicePath(locale, 'iso27001')} class="text-accent hover:text-accent/80 underline decoration-accent/30 hover:decoration-accent">
            Se ISO 27001-tjänsten
          </a>.
        </p>
      </div>
    </div>
  </section>
</PageLayout>
