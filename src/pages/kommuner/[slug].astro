---
import PageLayout from '@layouts/PageLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import Button from '@components/ui/Button.astro';
import CTABanner from '@components/sections/CTABanner.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import SwedenMap from '@components/ui/SwedenMap.astro';
import { site, organizationSchema } from '@data/site';
import {
  kommuner,
  getKommunMetaTitle,
  getKommunMetaDescription,
  getKommunFaq,
  getSectorLabel,
} from '@data/kommuner';
import type { Kommun } from '@data/kommuner';
import { getContactPath, getSecurapilotPath } from '@i18n/routes';

const locale = 'sv';

export async function getStaticPaths() {
  return kommuner.map((k) => ({
    params: { slug: k.slug },
    props: { kommun: k },
  }));
}

const { kommun } = Astro.props as { kommun: Kommun };

const metaTitle = getKommunMetaTitle(kommun);
const metaDescription = getKommunMetaDescription(kommun);
const faq = getKommunFaq(kommun);

const localServiceSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: `Verit, Cybersäkerhet & NIS2 i ${kommun.name}`,
  description: metaDescription,
  url: `${site.url}/kommuner/${kommun.slug}`,
  provider: {
    '@type': 'Organization',
    name: organizationSchema.name,
    url: organizationSchema.url,
    address: organizationSchema.address,
    telephone: organizationSchema.telephone,
  },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: kommun.name,
    containedInPlace: {
      '@type': 'State',
      name: kommun.county,
      addressCountry: 'SE',
    },
  },
  serviceType: 'Cybersäkerhetskonsulting',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Cybersäkerhetstjänster',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'NIS2-rådgivning' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'ISO 27001' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'CISO-as-a-Service' } },
    ],
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};

// Type-specific intro text
function getTypeIntro(k: Kommun): string {
  switch (k.type) {
    case 'industrial':
      return `${k.name} är en industrikommun med stark närvaro inom ${k.dominantSectors.slice(0, 3).map(getSectorLabel).join(', ').toLowerCase()}. Tillverkningssektorn med tillhörande leverantörskedjor berörs direkt av NIS2-direktivet och cybersäkerhetslagen. I en kommun som ${k.name}, där leverantörskedjorna ofta är långa och djupa, innebär det att betydligt fler företag än de direkt NIS2-klassificerade behöver se över sin cybersäkerhet.`;
    case 'major-city':
      return `${k.name} är en av Sveriges största kommuner med ett diversifierat näringsliv som spänner över ${k.dominantSectors.map(getSectorLabel).join(', ').toLowerCase()}. Den breda sektorsnärvaron innebär att cybersäkerhetslagen träffar ${k.name} på bred front, från kommunen och regionens verksamheter till hundratals privata företag. Dessutom kaskaderar NIS2:s leverantörskrav nedåt genom hela kedjan.`;
    case 'rural':
      return `${k.name} är en kommun med ${k.population.toLocaleString('sv-SE')} invånare i ${k.county}. Det kan vara lätt att tänka att cybersäkerhetslagen främst berör storstäder och storföretag, men ${k.name}s kommun och flera lokala verksamheter omfattas fullt ut. Samma krav gäller oavsett kommunens storlek, om än i en skala anpassad efter verksamhetens komplexitet.`;
    case 'service-city':
      return `${k.name} präglas av ${k.dominantSectors.slice(0, 3).map(getSectorLabel).join(', ').toLowerCase()}, sektorer som alla berörs av NIS2-direktivet och cybersäkerhetslagen. Många verksamheter i ${k.name} har redan erfarenhet av regulatorisk efterlevnad inom sina respektive områden. Cybersäkerhetslagen adderar specifika krav som bygger vidare på det befintliga arbetet.`;
  }
}

// Type-specific CTA section
function getTypeCallout(k: Kommun): { title: string; text: string } {
  switch (k.type) {
    case 'industrial':
      return {
        title: 'Leverantörskedjor och OT-säkerhet',
        text: `I en industrikommun som ${k.name} är OT-säkerhet (Operational Technology) en central fråga. Tillverkande företag med styrsystem, SCADA och industriella nätverk behöver säkerställa att dessa system omfattas av cybersäkerhetsarbetet, inte bara IT-miljön. NIS2 ställer explicita krav på supply chain security, vilket innebär att era storkunders NIS2-efterlevnad direkt påverkar kraven på er.`,
      };
    case 'major-city':
      return {
        title: 'Skalbarhet och samordning',
        text: `I en storstad som ${k.name} berörs verksamheter av flera tillsynsmyndigheter parallellt. Kommunala bolag kan omfattas i olika sektorer, och privata företag möter ofta krav från både NIS2 och sektorspecifik reglering. Det ställer höga krav på samordning, något där vår plattform Securapilot ger realtidsöverblick.`,
      };
    case 'rural':
      return {
        title: 'Proportionella åtgärder, anpassat efter er verklighet',
        text: `Cybersäkerhetslagen säger "lämpliga och proportionella åtgärder". Vi hjälper er tolka vad det betyder för just ${k.name}. Med CISO-as-a-Service får ni strategisk säkerhetsstyrning utan att behöva rekrytera specialistkompetens, och med Securapilot har ni löpande koll utan dyr årlig revision.`,
      };
    case 'service-city':
      return {
        title: 'Bygg vidare på det ni redan har',
        text: `Många verksamheter i ${k.name} arbetar redan med ISO 27001, GDPR eller sektorspecifika ramverk. NIS2 adderar krav på incidentrapportering inom 24 timmar, ledningsutbildning och anmälningsplikt, men mycket av grundarbetet är redan gjort. Vi hjälper er identifiera gapet och fylla det effektivt.`,
      };
  }
}

const typeIntro = getTypeIntro(kommun);
const typeCallout = getTypeCallout(kommun);
const typeImage = `/images/kommuner/${kommun.type}.webp`;
const heroImage = `/images/kommuner/hero-${kommun.type}.webp`;
---

<PageLayout title={metaTitle} description={metaDescription} ogImage={`/og/kommuner/${kommun.slug}.png`} locale={locale} svOnly={true} headerTheme="dark">
  <JsonLd schema={localServiceSchema} />
  <JsonLd schema={faqSchema} />
  <!-- Hero with background image -->
  <section class="relative -mt-20 pt-32 pb-20 overflow-hidden">
    <img
      src={heroImage}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-navy-dark/75"></div>
    <div class="container relative z-10">
      <div class="hero-breadcrumb">
        <Breadcrumb items={[{ label: 'Kommuner', href: '/kommuner' }, { label: kommun.name }]} locale={locale} />
      </div>
      <div class="max-w-3xl mt-6" data-reveal>
        <h1 class="text-white">{`Cybersäkerhet och NIS2 i ${kommun.name}`}</h1>
        <p class="lead mt-4 text-white/70">{`Uppskattningsvis ${kommun.nis2Estimate} organisationer i ${kommun.name} berörs av cybersäkerhetslagen. Vi hjälper företag och kommun att komma igång, pragmatiskt och steg för steg.`}</p>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section">
    <div class="container">
      <div class="grid lg:grid-cols-5 gap-12">
        <div class="lg:col-span-3" data-reveal>
          <p class="overline mb-4">Cybersäkerhet i {kommun.name}</p>
          <p class="text-lg text-slate leading-relaxed mb-6">{typeIntro}</p>
          <div class="grid sm:grid-cols-3 gap-4">
            <div class="bg-surface rounded-lg p-5 border border-border text-center">
              <span class="block text-2xl font-bold text-navy">{kommun.population.toLocaleString('sv-SE')}</span>
              <span class="text-sm text-gray">Invånare</span>
            </div>
            <div class="bg-surface rounded-lg p-5 border border-border text-center">
              <span class="block text-2xl font-bold text-accent-dark">~{kommun.nis2Estimate}</span>
              <span class="text-sm text-gray">NIS2-berörda organisationer</span>
            </div>
            <div class="bg-surface rounded-lg p-5 border border-border text-center">
              <span class="block text-2xl font-bold text-navy">{kommun.county}</span>
              <span class="text-sm text-gray">Län</span>
            </div>
          </div>
        </div>
        <div class="lg:col-span-2" data-reveal="right">
          <div class="lg:sticky" style="top: 2px;">
            <SwedenMap name={kommun.name} lat={kommun.lat} lng={kommun.lng} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NIS2-berörda sektorer -->
  <section class="section-sm bg-surface">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="overline mb-3">Berörda sektorer</p>
        <h2 class="mb-6">Vilka berörs i {kommun.name}?</h2>
        <p class="text-gray leading-relaxed mb-6">
          {kommun.name}s kommun omfattas av cybersäkerhetslagen som offentlig förvaltning. Kommunala bolag inom energi, vatten och digital infrastruktur berörs dessutom i sina respektive sektorer. Privata medelstora och stora företag inom följande sektorer omfattas:
        </p>
        <div class="grid sm:grid-cols-2 gap-3 mb-8">
          {kommun.dominantSectors.map((sector) => (
            <div class="flex items-center gap-3 bg-white rounded-lg px-5 py-4 border border-border">
              <div class="w-2 h-2 rounded-full bg-teal shrink-0"></div>
              <span class="text-sm font-medium text-navy">{getSectorLabel(sector)}</span>
            </div>
          ))}
        </div>
        <div class="bg-white rounded-lg p-5 border border-border">
          <h3 class="text-sm font-semibold text-navy mb-2">Tillsynsmyndigheter</h3>
          <p class="text-sm text-gray">
            Verksamheter i {kommun.name} övervakas beroende på sektor av: {kommun.tillsynsmyndigheter.join(', ')}. Kommunen som offentlig förvaltning hör under Länsstyrelsen i {kommun.county}s län.
          </p>
        </div>
        <div class="mt-8">
          <Button href={getContactPath(locale)} variant="primary" size="md">
            Boka ett kostnadsfritt möte
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Type-specific callout -->
  <section class="bg-navy-dark relative overflow-hidden">
    <img
      src={typeImage}
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-40"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-dark/90 via-navy-dark/70 to-navy-dark/50"></div>
    <div class="container section relative z-10">
      <div class="max-w-3xl" data-reveal>
        <h2 class="text-white mb-4">{typeCallout.title}</h2>
        <p class="text-lg text-white/60 leading-relaxed">{typeCallout.text}</p>
      </div>
    </div>
  </section>

  <!-- How we help -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="overline mb-3">Så kan vi hjälpa</p>
        <h2 class="mb-8">Pragmatiskt stöd, anpassat efter er verklighet</h2>
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-navy text-white font-bold">1</div>
            <div class="pt-0.5">
              <h3 class="font-semibold text-navy mb-1">Kolla läget</h3>
              <p class="text-sm text-gray">Vi gör en gap-analys som visar var ni står i förhållande till cybersäkerhetslagens krav. Ingen pärm som samlar damm, utan en tydlig bild av vad som faktiskt behöver göras.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-navy text-white font-bold">2</div>
            <div class="pt-0.5">
              <h3 class="font-semibold text-navy mb-1">Bygg det som saknas</h3>
              <p class="text-sm text-gray">Vi hjälper er implementera åtgärder anpassade efter er storlek och resurser. Från riskanalyser och policyer till incidenthanteringsprocesser.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-navy text-white font-bold">3</div>
            <div class="pt-0.5">
              <h3 class="font-semibold text-navy mb-1">Håll koll löpande</h3>
              <p class="text-sm text-gray">Med vår plattform Securapilot får ni realtidsöverblick över ert compliance-arbete. Istället för en årlig revision har ni alltid koll på statusen.</p>
            </div>
          </div>
        </div>
        <div class="flex flex-wrap gap-4 mt-10">
          <Button href={getContactPath(locale)} variant="primary" size="md">
            Boka ett kostnadsfritt möte
          </Button>
          <Button href={getSecurapilotPath(locale)} variant="outline" size="md">
            Se hur Securapilot fungerar
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-sm bg-surface">
    <div class="container">
      <div class="max-w-3xl" data-reveal>
        <p class="overline mb-3">Vanliga frågor</p>
        <h2 class="mb-8">NIS2 och cybersäkerhet i {kommun.name}</h2>
        <div class="space-y-3">
          {faq.map((item) => (
            <details class="group bg-white rounded-lg border border-border">
              <summary class="flex items-center justify-between px-5 py-4 cursor-pointer text-navy font-medium text-sm">
                {item.question}
                <svg class="w-5 h-5 text-gray shrink-0 ml-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-5 pb-4 text-sm text-gray leading-relaxed">
                {item.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    title={`Behöver ni hjälp med cybersäkerhet i ${kommun.name}?`}
    description="Vi berättar gärna mer om hur vi kan hjälpa er organisation med NIS2, ISO 27001 och cybersäkerhetslagen."
    locale={locale}
  />
</PageLayout>

<style>
  .hero-breadcrumb :global(ol) {
    color: rgba(255, 255, 255, 0.6);
  }
  .hero-breadcrumb :global(a) {
    color: rgba(255, 255, 255, 0.6);
  }
  .hero-breadcrumb :global(a:hover) {
    color: white;
  }
  .hero-breadcrumb :global(span) {
    color: white;
  }
  .hero-breadcrumb :global(svg) {
    color: rgba(255, 255, 255, 0.4);
  }
</style>
