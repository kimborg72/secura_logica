---
import PageLayout from '@layouts/PageLayout.astro';
import HeroSimple from '@components/sections/HeroSimple.astro';
import CTABanner from '@components/sections/CTABanner.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import { site } from '@data/site';
import { getKommunerByCounty, type KommunType } from '@data/kommuner';

const locale = 'sv';
const kommunerByCounty = getKommunerByCounty();

const typeBadge: Record<KommunType, { label: string; class: string }> = {
  'industrial': { label: 'Industri', class: 'bg-navy/10 text-navy' },
  'major-city': { label: 'Storstad', class: 'bg-accent/15 text-accent-dark' },
  'rural': { label: 'Glesbygd', class: 'bg-teal/15 text-teal-dark' },
  'service-city': { label: 'Tjänst', class: 'bg-copper/15 text-copper-dark' },
};

const collectionPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Cybersäkerhet & NIS2 per kommun',
  description: 'Verit hjälper kommuner och företag i hela Sverige med NIS2-efterlevnad, ISO 27001 och cybersäkerhet.',
  url: `${site.url}/kommuner`,
};
---

<PageLayout
  title="Cybersäkerhet & NIS2 per kommun | Alla kommuner i Sverige | Verit"
  description="Verit hjälper kommuner och företag i hela Sverige med NIS2-efterlevnad, ISO 27001 och cybersäkerhet. Hitta din kommun och se vilka verksamheter som berörs."
  ogImage="/og/kommuner.png"
  locale={locale}
  svOnly={true}
>
  <JsonLd schema={collectionPageSchema} />
  <HeroSimple
    title="Cybersäkerhet & NIS2 per kommun"
    description="Cybersäkerhetslagen berör alla Sveriges 290 kommuner, både som offentlig förvaltning och genom de privata företag som verkar lokalt. Hitta din kommun och se vilka verksamheter som berörs."
    breadcrumbs={[{ label: 'Kommuner' }]}
    locale={locale}
  />

  <section class="section">
    <div class="container">
      {Object.entries(kommunerByCounty).map(([county, kommunerList]) => (
        <div class="mb-12 last:mb-0" data-reveal>
          <h2 class="text-xl font-semibold text-navy mb-6 pb-3 border-b border-border">{county}</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {kommunerList.map((k) => (
              <a
                href={`/kommuner/${k.slug}`}
                class="flex items-center justify-between bg-surface hover:bg-white rounded-lg px-5 py-4 border border-border hover:border-accent/30 transition-colors group"
              >
                <div>
                  <span class="font-medium text-navy group-hover:text-accent-dark transition-colors">{k.name}</span>
                  <span class="block text-xs text-gray mt-0.5">
                    {k.population.toLocaleString('sv-SE')} inv. &middot; ~{k.nis2Estimate} NIS2-berörda
                  </span>
                </div>
                <span class={`text-xs font-medium px-2 py-1 rounded ${typeBadge[k.type].class}`}>
                  {typeBadge[k.type].label}
                </span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <CTABanner
    title="Hittar du inte din kommun?"
    description="Vi hjälper verksamheter i hela Sverige. Kontakta oss så berättar vi hur vi kan stödja just er."
    locale={locale}
  />
</PageLayout>
